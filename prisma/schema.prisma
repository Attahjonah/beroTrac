generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      UserRole @default(user)

  @@map("users")
}

model Sale {
  id            String        @id @default(uuid())
  department    String
  paymentMethod PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("sales")
}

model Expense {
  id          String   @id @default(uuid())
  department  String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model CashOut {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cash_outs")
}

model Pending {
  id          String    @id @default(uuid())
  department  String
  amount      Decimal   @db.Decimal(12, 2)
  description String?
  cleared     Boolean   @default(false)
  clearedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pendings")
}

model DepartmentSummary {
  id         String   @id @default(uuid())
  department String
  month      Int
  year       Int
  sales      Decimal  @db.Decimal(12, 2)
  posSales   Decimal  @db.Decimal(12, 2)
  cashSales  Decimal  @db.Decimal(12, 2)
  expenses   Decimal  @db.Decimal(12, 2)
  pending    Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cashOut    Decimal  @db.Decimal(12, 2)

  @@unique([department, month, year])
  @@map("department_summaries")
}

enum UserRole {
  admin
  user
}

enum PaymentMethod {
  pos
  cash
}
